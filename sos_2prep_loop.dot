digraph SoS2Prep {
    // Global Graph Settings
    graph [
        bgcolor="white"
        rankdir=TB
        nodesep=0.4
        ranksep=0.35
        pad=0.3
        fontname="Noto Sans CJK SC, Helvetica, sans-serif"
        splines=spline
        size="9,12!"
        ratio="fill"
    ]

    // Global Node Settings
    node [
        fontname="Noto Sans CJK SC, Helvetica, sans-serif"
        style="filled,rounded"
        shape=box
        penwidth=2
        margin="0.2,0.1"
    ]

    // Global Edge Settings
    edge [
        color="#94a3b8"
        penwidth=2.5
        fontname="Noto Sans CJK SC, Helvetica, sans-serif"
        fontcolor="#cbd5e0"
        fontsize=16
        arrowsize=0.8
    ]

    // Title
    title [shape=plaintext style="" fillcolor="none" penwidth=0 label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="2">
        <TR><TD ALIGN="CENTER"><B><FONT POINT-SIZE="28" COLOR="#b8860b">钢铁风暴+ + 2×早有准备+ 无限循环</FONT></B></TD></TR>
        <TR><TD ALIGN="CENTER"><FONT POINT-SIZE="16" COLOR="#666666">5张卡 · Guaranteed Infinite Combo · 对抗任意洗牌</FONT></TD></TR>
      </TABLE>
    >]

    // Anchor state
    anchor [color="#16a34a" fillcolor="#d1fae5" label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4">
        <TR><TD ALIGN="CENTER"><B><FONT COLOR="#2d6a4f" POINT-SIZE="20">🃏 锚定状态</FONT></B></TD></TR>
        <TR><TD ALIGN="CENTER"><FONT COLOR="#333333" POINT-SIZE="17">手牌：钢铁风暴+、战术大师+、本能反应+、准备+、准备+<BR/>费用：3 · 抽牌堆：∅ · 弃牌堆：∅</FONT></TD></TR>
      </TABLE>
    >]

    // Step 1: Play SoS (shared)
    step1 [color="#7c3aed" fillcolor="#ede9fe" label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="3">
        <TR><TD ALIGN="LEFT"><B><FONT COLOR="#5b21b6" POINT-SIZE="19">① 打出钢铁风暴+</FONT></B><FONT COLOR="#666666" POINT-SIZE="16"> (−1费 → 剩余4费)</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT COLOR="#333333" POINT-SIZE="17">弃掉全部4张手牌 → 生成4把匕首</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT COLOR="#92400e" POINT-SIZE="17">⚡ 战术大师+ 弃牌触发：+2费</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT COLOR="#92400e" POINT-SIZE="17">⚡ 本能反应+ 弃牌触发：抽3张</FONT></TD></TR>
      </TABLE>
    >]

    // Branch: Draw 3 from shuffle
    branch [color="#2563eb" fillcolor="#dbeafe" label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="3">
        <TR><TD ALIGN="LEFT"><B><FONT COLOR="#1e40af" POINT-SIZE="19">② 从5张牌的洗牌堆抽3张</FONT></B><FONT COLOR="#666666" POINT-SIZE="16"> (对手控制顺序)</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT COLOR="#333333" POINT-SIZE="17">牌堆：{钢铁风暴+, 战术大师+, 本能反应+, 准备+, 准备+}</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT COLOR="#666666" POINT-SIZE="16"><I>2张牌滞留在抽牌堆</I></FONT></TD></TR>
      </TABLE>
    >]

    // Branch decision
    decision [shape=diamond color="#f6e05e" fillcolor="#fefce8" penwidth=2.5 label=<
      <FONT COLOR="#b8860b" POINT-SIZE="17"><B>抽到的3张中有准备+?</B></FONT>
    >]

    // ============= NS BRANCH (left) =============
    ns_shivs [color="#dc2626" fillcolor="#fee2e2" label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="3">
        <TR><TD ALIGN="CENTER"><B><FONT COLOR="#991b1b" POINT-SIZE="18">③ 打出4把匕首</FONT></B><FONT COLOR="#666666" POINT-SIZE="15"> (0费)</FONT></TD></TR>
        <TR><TD ALIGN="CENTER"><B><FONT COLOR="#dc2626" POINT-SIZE="19">→ 16 点伤害</FONT></B></TD></TR>
      </TABLE>
    >]

    ns_prep [color="#7c3aed" fillcolor="#ede9fe" label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="3">
        <TR><TD ALIGN="LEFT"><B><FONT COLOR="#5b21b6" POINT-SIZE="18">④ 打出准备+</FONT></B><FONT COLOR="#666666" POINT-SIZE="15"> (0费)</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT COLOR="#333333" POINT-SIZE="16">抽2张（取回滞留的牌）</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT COLOR="#333333" POINT-SIZE="16">弃2张：战术大师+ 和 本能反应+</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT COLOR="#92400e" POINT-SIZE="16">⚡ +2费 · ⚡ 抽3张</FONT></TD></TR>
      </TABLE>
    >]

    ns_draw3 [color="#2563eb" fillcolor="#dbeafe" label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="3">
        <TR><TD ALIGN="LEFT"><B><FONT COLOR="#1e40af" POINT-SIZE="18">⑤ 从3张牌的洗牌堆抽3张</FONT></B></TD></TR>
        <TR><TD ALIGN="LEFT"><B><FONT COLOR="#166534" POINT-SIZE="16">✅ 3张全部抽回——对手无法控制</FONT></B></TD></TR>
      </TABLE>
    >]

    // ============= PS BRANCH (right) =============
    ps_shivs1 [color="#dc2626" fillcolor="#fee2e2" label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="3">
        <TR><TD ALIGN="CENTER"><B><FONT COLOR="#991b1b" POINT-SIZE="18">③ 打出4把匕首</FONT></B><FONT COLOR="#666666" POINT-SIZE="15"> (0费)</FONT></TD></TR>
        <TR><TD ALIGN="CENTER"><B><FONT COLOR="#dc2626" POINT-SIZE="19">→ 16 点伤害</FONT></B></TD></TR>
      </TABLE>
    >]

    ps_sos2 [color="#7c3aed" fillcolor="#ede9fe" label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="3">
        <TR><TD ALIGN="LEFT"><B><FONT COLOR="#5b21b6" POINT-SIZE="18">④ 再次打出钢铁风暴+</FONT></B><FONT COLOR="#666666" POINT-SIZE="15"> (−1费)</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT COLOR="#333333" POINT-SIZE="16">弃掉战术大师+和本能反应+ → 生成2把匕首</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT COLOR="#92400e" POINT-SIZE="16">⚡ +2费 · ⚡ 抽3张</FONT></TD></TR>
      </TABLE>
    >]

    ps_draw [color="#2563eb" fillcolor="#dbeafe" label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="3">
        <TR><TD ALIGN="LEFT"><B><FONT COLOR="#1e40af" POINT-SIZE="18">⑤ 抽3张</FONT></B></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT COLOR="#333333" POINT-SIZE="16">从抽牌堆取回2张准备+ + 从洗牌堆抽1张</FONT></TD></TR>
      </TABLE>
    >]

    ps_shivs2 [color="#dc2626" fillcolor="#fee2e2" label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="3">
        <TR><TD ALIGN="CENTER"><B><FONT COLOR="#991b1b" POINT-SIZE="18">⑥ 打出2把匕首</FONT></B><FONT COLOR="#666666" POINT-SIZE="15"> (0费)</FONT></TD></TR>
        <TR><TD ALIGN="CENTER"><B><FONT COLOR="#dc2626" POINT-SIZE="19">→ 8 点伤害</FONT></B></TD></TR>
      </TABLE>
    >]

    ps_prep [color="#7c3aed" fillcolor="#ede9fe" label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="3">
        <TR><TD ALIGN="LEFT"><B><FONT COLOR="#5b21b6" POINT-SIZE="18">⑦ 打出准备+</FONT></B><FONT COLOR="#666666" POINT-SIZE="15"> (0费)</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT COLOR="#333333" POINT-SIZE="16">抽2张（洗牌堆剩余）· 弃2张：战术大师+和本能反应+</FONT></TD></TR>
        <TR><TD ALIGN="LEFT"><FONT COLOR="#92400e" POINT-SIZE="16">⚡ +2费 · ⚡ 抽3张</FONT></TD></TR>
      </TABLE>
    >]

    ps_draw3 [color="#2563eb" fillcolor="#dbeafe" label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="3">
        <TR><TD ALIGN="LEFT"><B><FONT COLOR="#1e40af" POINT-SIZE="18">⑧ 从3张牌的洗牌堆抽3张</FONT></B></TD></TR>
        <TR><TD ALIGN="LEFT"><B><FONT COLOR="#166534" POINT-SIZE="16">✅ 3张全部抽回——对手无法控制</FONT></B></TD></TR>
      </TABLE>
    >]

    // ============= MERGE =============
    loop [color="#16a34a" fillcolor="#d1fae5" label=<
      <TABLE BORDER="0" CELLBORDER="0" CELLSPACING="0" CELLPADDING="4">
        <TR><TD ALIGN="CENTER"><B><FONT COLOR="#2d6a4f" POINT-SIZE="20">🔄 回到锚定状态</FONT></B></TD></TR>
        <TR><TD ALIGN="CENTER"><FONT COLOR="#666666" POINT-SIZE="16">sameModAccum ✓ · dealtDamage ✓ · noEndTurn ✓</FONT></TD></TR>
      </TABLE>
    >]


    // ============= EDGES =============
    title -> anchor [style=invis]
    anchor -> step1
    step1 -> branch
    branch -> decision

    // NS branch (left)
    decision -> ns_shivs [label=<  <FONT COLOR="#166534"><B>有 (NS)</B></FONT>  > color="#48bb78"]
    ns_shivs -> ns_prep
    ns_prep -> ns_draw3
    ns_draw3 -> loop

    // PS branch (right)
    decision -> ps_shivs1 [label=<  <FONT COLOR="#dc2626"><B>无 (PS)</B></FONT>  > color="#fc8181"]
    ps_shivs1 -> ps_sos2
    ps_sos2 -> ps_draw
    ps_draw -> ps_shivs2
    ps_shivs2 -> ps_prep
    ps_prep -> ps_draw3
    ps_draw3 -> loop

    // Loop back
    loop -> anchor [label="  ∞  " color="#16a34a" penwidth=3 fontcolor="#16a34a" fontsize=30]


    // Layout hints
    {rank=same; ns_shivs; ps_shivs1}
    {rank=same; ns_draw3; ps_draw3}
}
